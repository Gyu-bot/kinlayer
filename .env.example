KINLAYER_API_URL=http://127.0.0.1:8765
VITE_KINLAYER_API_URL=

# Optional local bearer token. Leave empty for the simplest local setup.
KINLAYER_API_TOKEN=

KINLAYER_DATABASE_URL=postgresql+psycopg://kinlayer:kinlayer@127.0.0.1:15432/kinlayer
KINLAYER_SELF_NAME=Self

# Optional OpenAI embeddings. Leave empty to run without semantic embeddings.
# Setting this key enables the built-in OpenAI defaults:
# provider openai_compatible, model text-embedding-3-small, dim 1536.
KINLAYER_EMBEDDING_API_KEY=
